{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 8,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "x64-release",
      "displayName": "x64 Release (CUDA OFF)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_x64_release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "GS2PC_ENABLE_CUDA_RASTER": "OFF"
      }
    },
    {
      "name": "x64-release-cuda",
      "displayName": "x64 Release (CUDA ON)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_cuda_x64_release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "GS2PC_ENABLE_CUDA_RASTER": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "x64-release",
      "displayName": "Build x64 Release (CUDA OFF)",
      "configurePreset": "x64-release"
    },
    {
      "name": "x64-release-cuda",
      "displayName": "Build x64 Release (CUDA ON)",
      "configurePreset": "x64-release-cuda"
    }
  ]
}
